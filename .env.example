# ── Azure OpenAI GPT-5.0 ──
AI_ENDPOINT=https://your-resource.openai.azure.com/
AI_API_KEY=your-azure-api-key
AI_DEPLOY_MODEL=gpt-5
AI_API_VERSION=2024-12-01-preview

# ── 서버 설정 ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── LLM 호출 설정 ──
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=120

# ── Mock 모드 (LLM 호출 없이 테스트) ──
# LLM_MOCK_MODE=true

# ── Dry-run 설정 ──
DRYRUN_STATEMENT_TIMEOUT_MS=5000

# ── 앱 DB (프로젝트 정보 영속 저장) ──
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=sql_migrator_app
APP_DB_USER=your_username
APP_DB_PASSWORD=
