# ── Azure OpenAI ──
AI_ENDPOINT=https://your-resource.openai.azure.com/
AI_API_KEY=your-azure-api-key
AI_DEPLOY_MODEL=gpt-4o
AI_API_VERSION=2024-12-01-preview

# ── 서버 설정 ──
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── LLM 호출 설정 ──
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=120

# ── Mock 모드 (LLM 호출 없이 테스트, true 설정 시 AI 없이 동작) ──
LLM_MOCK_MODE=false

# ── Dry-run 설정 (ms) ──
DRYRUN_STATEMENT_TIMEOUT_MS=5000

# ── 앱 DB (프로젝트 정보 영속 저장) ──
# 방법 1: URL 방식 (Neon, Supabase 등 클라우드 DB — 권장)
# APP_DB_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require

# 방법 2: 개별 항목 방식 (APP_DB_URL 비워두면 아래 항목 사용)
APP_DB_HOST=localhost
APP_DB_PORT=5432
APP_DB_NAME=sql_migrator_app
APP_DB_USER=your_username
APP_DB_PASSWORD=your_password
