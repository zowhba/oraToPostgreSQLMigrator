<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.skb.edmp.admin.store.common.ConnLogMapper">

    <select id="selectConnLog"
    resultType="hashMap">

    <![CDATA[
    SELECT
         user_id
        ,user_conn_date
        ,user_conn_ipaddr
        ,user_work_fg_cd
        ,user_work_cts
    FROM ad_user_conn_log
    ]]>
    </select>

    <insert id="insertConnLog"
    parameterType="com.skb.edmp.admin.dto.common.ConnLogDTO">

    <![CDATA[
    INSERT INTO AD_USER_CONN_LOG
    (
     user_id
    ,user_conn_date
    ,user_conn_ipaddr
    ,user_work_fg_cd
    ,user_work_cts
    ,edmp_mgmt_cd
    )
    VALUES
    (
     #{userId}
    ,SYSDATE
    ,#{userConnIpaddr}
    ,#{userWorkFgCd}
    ,#{userWorkCts}
    ,#{edmpMgmtCd}
    )
    ]]>
    </insert>

</mapper>