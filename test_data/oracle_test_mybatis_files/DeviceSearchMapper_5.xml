                #{type}
                    </foreach>
                </if>

                <if test="networkList.size != 0 and !networkList.equals('')">
                AND STB.NETWORK_BRAND_CODE IN
                    <foreach collection="networkList" item="type" index="index" open="(" close=")" separator=",">
                #{type}
                    </foreach>
                </if>

                <if test="openingStateList.size != 0 and !openingStateList.equals('')">
                AND STB.IPTV_STATUS_CODE IN
                    <foreach collection="openingStateList" item="type" index="index" open="(" close=")" separator=",">
                #{type}
                    </foreach>
                </if>

                <if test="joinProductList.size != 0 and !joinProductList.equals('')">
                AND STB.ID_PACKAGE IN
                    <foreach collection="joinProductList" item="type" index="index" open="(" close=")" separator=",">
                #{type}
                    </foreach>
                </if>

                <if test="scrbrTypCdList != null and scrbrTypCdList.size != 0 and !scrbrTypCdList.equals('')">
                    AND SD.SCRBR_TYP_CD IN
                    <foreach collection="scrbrTypCdList" item="type" index="index" open="(" close=")" separator=",">
                        #{type}
                    </foreach>
                </if>

                <choose>
                    <when test='uptime.equals("1")'>
                        <if test="!fromUptm.equals('') and !toUptm.equals('')">
                            <choose>
                                <when test='check.equals("3")'>
                    AND DDM.STM_UPTM BETWEEN TO_DATE(#{fromUptm}||'00:00:00','yyyyMMdd HH24:MI:SS')
                                          AND TO_DATE(#{toUptm}||'23:59:59','yyyyMMdd HH24:MI:SS')
                                </when>
                                <when test="!fromUptm.equals('')">
                                    <if test='check.equals("4")'>
                    AND DDM.STM_UPTM BETWEEN TO_DATE(#{fromUptm}||'00:00:00','yyyyMMdd HH24:MI:SS')
                                          AND TO_DATE(#{fromUptm}||'23:59:59','yyyyMMdd HH24:MI:SS')
                                    </if>
                                    <if test='check.equals("1")'>
                    AND DDM.STM_UPTM <![CDATA[>=]]> TO_DATE(#{fromUptm})
