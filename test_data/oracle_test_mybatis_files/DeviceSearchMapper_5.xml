                            <choose>
                                <when test='check.equals("3")'>
                    AND DDM.STM_UPTM BETWEEN TO_DATE(#{fromUptm}||'00:00:00','yyyyMMdd HH24:MI:SS')
                                          AND TO_DATE(#{toUptm}||'23:59:59','yyyyMMdd HH24:MI:SS')
                                </when>
                                <when test="!fromUptm.equals('')">
                                    <if test='check.equals("4")'>
                    AND DDM.STM_UPTM BETWEEN TO_DATE(#{fromUptm}||'00:00:00','yyyyMMdd HH24:MI:SS')
                                          AND TO_DATE(#{fromUptm}||'23:59:59','yyyyMMdd HH24:MI:SS')
                                    </if>
                                    <if test='check.equals("1")'>
                    AND DDM.STM_UPTM <![CDATA[>=]]> TO_DATE(#{fromUptm})
                                    </if>
                                    <if test='check.equals("2")'>
                    AND DDM.STM_UPTM <![CDATA[<=]]> TO_DATE(#{fromUptm})+0.99999
                                    </if>
                                </when>
                            </choose>
                        </if>
                    </when>
                    <when test='uptime.equals("2")'>
                        <choose>
                            <when test='check.equals("3")'>
                    <!-- AND TRUNC(SYSDATE) - TRUNC(DDM.STM_UPTM) BETWEEN #{overTimeFrom} and #{overTimeTo} -->
                    AND DDM.STM_UPTM BETWEEN TRUNC(SYSDATE-#{overTimeTo}) AND TRUNC(SYSDATE-#{overTimeFrom})+0.99999
                            </when>
                            <when test="!overTime.equals('')">
                                <if test='check.equals("4")'>
                    <!-- AND TRUNC(SYSDATE) - TRUNC(DDM.STM_UPTM) = #{overTime} -->
                    AND DDM.STM_UPTM BETWEEN TRUNC(SYSDATE-#{overTime}) AND TRUNC(SYSDATE-#{overTime})+0.99999
                                </if>
                                <if test='check.equals("1")'>
                    <!-- AND TRUNC(SYSDATE) - TRUNC(DDM.STM_UPTM) >= #{overTime} -->
                    AND STM_UPTM <![CDATA[<=]]> TRUNC(SYSDATE-#{overTime})+0.99999
                                </if>
                                <if test='check.equals("2")'>
                    <!-- AND TRUNC(SYSDATE) - TRUNC(DDM.STM_UPTM) <= #{overTime} -->
                    AND STM_UPTM <![CDATA[>=]]> TRUNC(SYSDATE-#{overTime})
                                </if>
                            </when>
                        </choose>
                    </when>
                </choose>

                <if test='stbDivision.equals("02")'>
                AND LENGTH(STB.USER_SERVICE_NUM) = 10
                </if>
                <if test='stbDivision.equals("03")'>
                AND LENGTH(STB.USER_SERVICE_NUM) != 10
                </if>

            </otherwise>
        </choose>

    </select>

    <select id="selectListTotalMassiveSearch" parameterType="com.skb.edmp.admin.dto.device.DeviceDTO" resultType="com.skb.edmp.admin.dto.device.DeviceDTO">
      SELECT
             DDM.STB_ID
        FROM
             STB STB
            ,DM_DVC_MST DDM
            ,PHYSICAL_STB PS
                                                <!--             ,DM_DVC_PRVN_MST DDPM -->
          WHERE 1=1
            AND DDM.STB_ID = STB.STB_ID
            AND DDM.STB_ID = PS.STB_ID (+)
                                                <!--             AND DDM.STB_ID = DDPM.STB_ID (+) -->
        <!-- <if test="searchData.size != 0">
            AND UPPER(${searchType}) IN
            <foreach collection="searchData" item="type" index="index" open="(" close=")" separator=",">
            UPPER(#{type})
            </foreach>
        </if> -->
        <if test="searchData.size != 0">
	            AND ${searchType} IN
            <choose>
                <when test='searchType.equals("ddm.stb_id")'>
                    <foreach collection="searchData" item="type" index="index" open="(" close=")" separator=",">
		            UPPER(#{type})
                    </foreach>
                </when>
                <otherwise>
                    <foreach collection="searchData" item="type" index="index" open="(" close=")" separator=",">
		            LOWER(#{type})
                    </foreach>
                </otherwise>
            </choose>
        </if>
    </select>


</mapper>
