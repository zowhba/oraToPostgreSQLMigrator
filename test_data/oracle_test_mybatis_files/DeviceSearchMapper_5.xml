        </choose>

    </select>



    <!--      검색 조건 없을 때 빠른 Count 쿼리 -->
    <select id="selectOneTotCntDeviceMstNoCondition" parameterType="com.skb.edmp.admin.dto.device.DeviceDTO" resultType="com.skb.edmp.admin.dto.device.DeviceDTO">
      SELECT 
            COUNT(1) TOTAL
      FROM
            DM_DVC_MST DDM
            ,STB
            ,PHYSICAL_STB PS
            ,DM_DVC_ACC_MST DADM
      where
      		DDM.STB_ID = STB.STB_ID
            AND DDM.STB_ID = PS.STB_ID (+)
    </select>



    <select id="selectOneGroupNm" parameterType="com.skb.edmp.admin.dto.device.DeviceDTO" resultType="com.skb.edmp.admin.dto.device.DeviceDTO">
        <![CDATA[
    SELECT LISTAGG(B.DVC_GRP_NM,',') WITHIN GROUP(ORDER BY B.DVC_GRP_NM) DVCGRPNM
      FROM DM_DVC_GRP_PSNL_MAP A
          ,DM_DVC_GRP_MST B
     WHERE 1=1
       AND A.DVC_GRP_ID = B.DVC_GRP_ID
       AND A.STB_ID = UPPER(#{stbId})
      GROUP BY A.STB_ID
    ]]>
    </select>

